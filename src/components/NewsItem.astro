---
// NewsItem.astro
const { date, title } = Astro.props;
---
<div class="news-item">
  <span class="date">{date}</span>
  <h3 class="title">{title}</h3>
</div>

<style>
  .news-item { margin-bottom: 1rem; padding: 10px; border-bottom: 1px solid #ccc; }
  .date { color: #666; font-size: 0.9rem; }
  .title { margin: 5px 0 0; }
</style>