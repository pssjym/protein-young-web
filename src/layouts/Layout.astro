---
interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8">
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@1,700;1,900&display=swap" rel="stylesheet">
    </head>
    <body>
        <div class="p3-background">
            <div class="light-rays"></div>
            <div class="overlay"></div>
            <slot /> 
        </div>
    </body>
</html>

<style is:global>
    :root {
        --bg-blue: #0055ff;  /* 右側の青 */
        --bg-white: #ffffff; /* 左側の白 */
    }

    body {
        margin: 0;
        background-color: var(--bg-white);
        color: white;
        font-family: 'Barlow Condensed', sans-serif;
        overflow-x: hidden;
    }

    /* クラス名を p3-background に統一 */
    .p3-background {
        min-height: 100vh;
        width: 100vw;
        /* 【修正ポイント1】右から左へのグラデーションを有効化！ */
        background: linear-gradient(to left, var(--bg-blue) 0%, #88bbff 50%, var(--bg-white) 100%);
        position: relative;
        /* 【修正ポイント2】これがないと光の帯がはみ出して画面が壊れます */
        overflow: hidden; 
    }

    /* --- 水中の光の帯（Light Rays） --- */
    .light-rays {
        position: absolute;
        top: -50%; 
        left: -50%; 
        width: 200%; 
        height: 200%;
        /* 光の強さを少し上げて見やすくしました (0.08 -> 0.15) */
        background: repeating-linear-gradient(
            to right,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.15) 10%, 
            rgba(255, 255, 255, 0) 20%
        );
        transform: rotate(25deg);
        animation: rays-move 15s linear infinite;
        pointer-events: none; 
        z-index: 1; 
    }

    @keyframes rays-move {
        0% { transform: rotate(25deg) translateX(0); }
        100% { transform: rotate(25deg) translateX(20%); } /* ゆっくり横に流れる */
    }

    /* P3R特有の青いオーバーレイ */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba(0, 85, 255, 0.05) 0%, transparent 100%);
        pointer-events: none;
        z-index: 2;
    }
</style>